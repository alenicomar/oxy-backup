# GitHub Actions workflow example for backup-lite
# ================================================
# Runs a daily backup of all configured databases via cron.
#
# Prerequisites:
#   1. A backup-lite.yaml committed to the repo (or mounted via secrets).
#   2. Repository secrets for database credentials.
#   3. Git configured to allow pushes from Actions (deploy key or PAT).

name: Scheduled Database Backup

on:
  schedule:
    # Run daily at 02:00 UTC
    - cron: "0 2 * * *"
  workflow_dispatch: # Allow manual trigger

permissions:
  contents: write

jobs:
  backup:
    runs-on: ubuntu-latest

    services:
      # Example: if backing up a containerized DB in CI
      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: ${{ secrets.PG_PASSWORD }}
          POSTGRES_DB: app_db
        ports:
          - 5432:5432
        options: >-
          --health-cmd="pg_health_check"
          --health-interval=10s
          --health-timeout=5s
          --health-retries=5

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "1.25"

      - name: Build backup-lite
        run: go build -o backup-lite ./cmd/backup-lite/

      - name: Configure Git
        run: |
          git config user.name "backup-lite[bot]"
          git config user.email "backup-lite@users.noreply.github.com"

      - name: Run backup
        env:
          PGPASSWORD: ${{ secrets.PG_PASSWORD }}
          APP_DB_PASSWORD: ${{ secrets.APP_DB_PASSWORD }}
        run: |
          ./backup-lite backup \
            --config backup-lite.yaml \
            --log-format json \
            --log-level info

      - name: Push backup changes
        run: |
          git push origin main
